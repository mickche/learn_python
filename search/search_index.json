{"config":{"lang":["en"],"separator":"[\\s\\-]+","pipeline":["stopWordFilter"],"fields":{"title":{"boost":1000.0},"text":{"boost":1.0},"tags":{"boost":1000000.0}}},"docs":[{"location":"","title":"Hello world","text":"<p>\u0412\u0441\u0456\u043c \u041f\u0440\u0438\u0432\u0456\u0442\u0438\u043a 0_0 \u041c\u0435\u043d\u0435 \u0437\u0432\u0443\u0442\u044c \u041c\u0438\u0445\u0430\u0439\u043b\u043e \u0456 \u043c\u0435\u043d\u0456 11 \u0440\u043e\u043a\u0456\u0432  \u042f \u0441\u0442\u0432\u043e\u0440\u044e\u044e \u0446\u0435\u0439 \u0441\u0430\u0439\u0442 \u0434\u043b\u044f \u0442\u0438\u0445 \u043a\u043e\u043c\u0443 \u043f\u043e\u0434\u043e\u0431\u0430\u0454\u0442\u044c\u0441\u044f \u0449\u043e\u0441\u044c \u043d\u043e\u0432\u0435 \u0432\u0438\u0432\u0447\u0430\u0442\u0438  \u043d\u0430 \u0446\u044c\u043e\u043c\u0443 \u0441\u0430\u0439\u0442\u0456 \u0432\u0438 \u0432\u0438\u0432\u0447\u0435\u0442\u0435 \u043e\u0441\u043d\u043e\u0432\u0443 \u043c\u043e\u0432\u0438 \u043f\u0440\u043e\u0433\u0440\u0430\u043c\u0443\u0432\u0430\u043d\u043d\u044f \"Pyhton\"</p> main.py<pre><code>print('Hello world')\n</code></pre>"},{"location":"json_vs_jsonl/","title":"json_vs_jsonl","text":""},{"location":"json_vs_jsonl/#jsonl-json","title":"\u0427\u0438\u043c JSONL \u043a\u0440\u0430\u0449\u0435 \u0437\u0430 JSON?","text":""},{"location":"json_vs_jsonl/#_1","title":"\u041f\u043e \u043f\u0435\u0440\u0448\u0435, \u0439\u043e\u0433\u043e \u0435\u043a\u043e\u043d\u043e\u043c\u0456\u044f \u043e\u043f\u0435\u0440\u0430\u0442\u0438\u0432\u043d\u043e\u0457 \u043f\u0430\u043c'\u044f\u0442\u0456","text":"<p>\u041a\u043e\u043b\u0438 \u0432\u0438 \u0449\u043e\u0441\u044c \u0440\u043e\u0431\u0438\u0442\u0435 \u0437 \u0444\u0430\u0439\u043b\u043e\u043c \u0442\u043e \u043f\u0438 \u043f\u043e \u0441\u0442\u0440\u0456\u0447\u0446\u0456 \u043f\u0435\u0440\u0435\u0432\u0456\u0440\u044f\u0454\u0442\u0435, \u0437\u0430\u043c\u0456\u0441\u0442\u044c \u0432\u0441\u044c\u043e\u0433\u043e \u0444\u0430\u0439\u043b\u0443 \u0426\u0435 \u0431\u0443\u0434\u0435 \u0432\u0438\u0434\u043d\u043e \u044f\u043a\u0449\u043e \u0432 \u0432\u0430\u0441 \u0431\u0443\u0434\u0435 JSON \u043d\u0430 10000000+ \u0441\u0442\u0440\u0456\u0447\u043e\u043a \"(\u0422\u0430\u043a\u0456 \u0454)\"</p>"},{"location":"json_vs_jsonl/#_2","title":"\u041f\u043e \u0434\u0440\u0443\u0433\u0435, \u0446\u0435 \u0441\u0442\u0456\u0439\u043a\u0456\u0441\u0442\u044c \u0434\u043e \u043f\u043e\u043c\u0438\u043b\u043e\u043a","text":"<p>\u042f\u043a\u0449\u043e \u0432 JSON \u0431\u0443\u0434\u0435 \u0445\u043e\u0447 \u043e\u0434\u043d\u0430 \u043f\u043e\u043c\u0438\u043b\u043a\u0430, \u0432\u0441\u0435 \u0437\u043b\u0430\u043c\u0430\u0454\u0442\u044c\u0441\u044f \u0410 \u0443 JSONL \u0432\u0438 \u043c\u043e\u0436\u0435\u0442\u0435 \u043f\u0440\u043e\u0441\u0442\u043e \u0434\u043e\u043f\u0438\u0441\u0443\u0432\u0430\u0442\u0438 \u043d\u043e\u0432\u0456 \u0440\u044f\u0434\u043a\u0438 \u0432 \u043a\u0456\u043d\u0435\u0446\u044c \u0444\u0430\u0439\u043b\u0443. \u042f\u043a\u0449\u043e \u043f\u0440\u043e\u0433\u0440\u0430\u043c\u0430 \u0432\u0438\u043b\u0435\u0442\u0438\u0442\u044c, \u0432\u0438 \u0432\u0442\u0440\u0430\u0442\u0438\u0442\u0435 \u043b\u0438\u0448\u0435 \u0442\u043e\u0439 \u043e\u0434\u0438\u043d \u0440\u044f\u0434\u043e\u043a, \u044f\u043a\u0438\u0439 \u0437\u0430\u043f\u0438\u0441\u0443\u0432\u0430\u0432\u0441\u044f \u0432 \u0446\u0435\u0439 \u043c\u043e\u043c\u0435\u043d\u0442. \u0406\u043d\u0448\u0456 \u0434\u0430\u043d\u0456 \u043d\u0435 \u043f\u043e\u0441\u0442\u0440\u0430\u0436\u0434\u0430\u044e\u0442\u044c.</p>"},{"location":"json_vs_jsonl/#_3","title":"\u041f\u043e\u0440\u0456\u0432\u043d\u044f\u043d\u043d\u044f \u043a\u043e\u0434\u0443","text":"jsonjsonl <pre><code>    [\n    {\"id\": 1, \"name\": \"\u041e\u043b\u0435\u043a\u0441\u0456\u0439\", \"role\": \"admin\"},\n    {\"id\": 2, \"name\": \"\u041a\u0456\u0440\u0456\u043b\u043b\", \"role\": \"user_devops\"},\n    {\"id\": 3, \"name\": \"\u0406\u0440\u0430\", \"role\": \"best_user\"}\n    ]\n</code></pre> <pre><code>{\"id\": 1, \"name\": \"\u041e\u043b\u0435\u043a\u0441\u0456\u0439\", \"role\": \"admin\"}\n{\"id\": 2, \"name\": \"\u041a\u0456\u0440\u0456\u043b\u043b\", \"role\": \"user_devops\"}\n{\"id\": 3, \"name\": \"\u0406\u0440\u0430\", \"role\": \"best_user\"}\n</code></pre>"},{"location":"json_vs_jsonl/#_4","title":"\u0427\u0438\u0442\u0430\u043d\u043d\u044f","text":"jsonjsonl <pre><code>import json\n\nwith open(\"data.json\", \"r\", encoding=\"utf-8\") as f:\n    data = json.load(f)\n\nfor item in data:\n    print(item[\"name\"])\n</code></pre> <pre><code>import json\n\nwith open(\"data.jsonl\", \"r\", encoding=\"utf-8\") as f:\n    for line in f:\n        item = json.loads(line.strip())\n        print(item[\"name\"])\n</code></pre> <p>\u042f\u043a \u044f \u0432\u0436\u0435 \u043a\u0430\u0437\u0430\u0432 \u0440\u0430\u043d\u0456\u0448\u0435, \u044f\u043a\u0449\u043e JSON \u0431\u0443\u0434\u0435 \u0432\u0435\u043b\u0438\u043a\u0438\u043c, \u0442\u043e \u0432\u0456\u043d \u0431\u0443\u0434\u0435 \u043d\u0430\u0432\u0430\u043d\u0442\u0430\u0436\u0443\u0432\u0430\u0442\u0438 \u043e\u043f\u0435\u0440\u0430\u0442\u0438\u0432\u043d\u0443 \u043f\u0430\u043c'\u044f\u0442\u044c</p> <p>\u0410 JSONL \u043d\u0430\u0432\u0430\u043d\u0442\u0430\u0436\u0443\u0454 \u043c\u0435\u043d\u0448\u0435, \u0431\u043e \u0432\u0456\u043d \u043f\u0435\u0440\u0435\u0432\u0456\u0440\u044f\u0454 \u043f\u043e \u0441\u0442\u0440\u0456\u0447\u0446\u0456</p>"},{"location":"json_vs_jsonl/#_5","title":"\u0414\u043e\u0434\u0430\u0432\u0430\u043d\u043d\u044f","text":"jsonjsonl <pre><code>import json\ndata = [\n    {\"name\": \"Alice\", \"age\": 25},\n    {\"name\": \"Bob\", \"age\": 30}\n    ]\n\nwith open('data.json', 'w') as f:\n    json.dump(data, f,)\n</code></pre> <pre><code>import json\n\ndata = [\n    {\"name\": \"Alice\", \"age\": 25},\n    {\"name\": \"Bob\", \"age\": 30}\n    ]\n\nwith open('data.jsonl', 'w') as f:\n    for item in data:\n        f.write(json.dumps(item))\n</code></pre> <p>\u042f\u043a\u0449\u043e \u043f\u043e\u0440\u0456\u0432\u043d\u044e\u0432\u0430\u0442\u0438 \u0442\u043e JSONL \u043a\u0440\u0430\u0449\u0435, \u044f\u043a\u0449\u043e \u0431\u0443\u0434\u0435 \u044f\u043a\u0430\u0441\u044c \u043f\u043e\u043c\u0438\u043b\u043a\u0430 \u0432 \u043d\u0430\u043f\u0438\u0441\u0430\u043d\u0456 \u043a\u043e\u0434\u0443 \u0442\u043e \u0432\u0441\u0435 \u0449\u043e \u0437\u0431\u0435\u0440\u0456\u0433\u043b\u043e\u0441\u044f \u0440\u0430\u043d\u0456\u0448\u0435, \u0431\u0443\u0434\u0435 \u0432 \u0444\u0430\u0439\u043b\u0456</p>"},{"location":"list/","title":"1. \u0429\u043e \u0442\u0430\u043a\u0435 \u0441\u043f\u0438\u0441\u043e\u043a?","text":"<p>\u0421\u043f\u0438\u0441\u043e\u043a \u2014 \u0446\u0435 \u0432\u043f\u043e\u0440\u044f\u0434\u043a\u043e\u0432\u0430\u043d\u0430 \u043a\u043e\u043b\u0435\u043a\u0446\u0456\u044f \u0435\u043b\u0435\u043c\u0435\u043d\u0442\u0456\u0432. \u041a\u0443\u0434\u0438 \u043c\u043e\u0436\u043d\u0430 \u043f\u043e\u043a\u043b\u0430\u0441\u0442\u0438 \u0449\u043e \u0437\u0430\u0432\u0433\u043e\u0434\u043d\u043e: \u0447\u0438\u0441\u043b\u0430, \u0442\u0435\u043a\u0441\u0442 \u0430\u0431\u043e \u043d\u0430\u0432\u0456\u0442\u044c \u0456\u043d\u0448\u0456 \u0441\u043f\u0438\u0441\u043a\u0438.</p> <ul> <li> <p>\u0421\u043f\u0438\u0441\u043e\u043a \u0441\u0442\u0432\u043e\u0440\u044e\u0454\u0442\u044c\u0441\u044f \u0437\u0430 \u0434\u043e\u043f\u043e\u043c\u043e\u0433\u043e\u044e \u043a\u0432\u0430\u0434\u0440\u0430\u0442\u043d\u0438\u0445 \u0434\u0443\u0436\u043e\u043a [].</p> </li> <li> <p>\u0415\u043b\u0435\u043c\u0435\u043d\u0442\u0438 \u0432\u0441\u0435\u0440\u0435\u0434\u0438\u043d\u0456 \u0440\u043e\u0437\u0434\u0456\u043b\u044f\u044e\u0442\u044c\u0441\u044f \u043a\u043e\u043c\u0430\u043c\u0438.</p> </li> </ul> <pre><code>    # \u041f\u043e\u0440\u043e\u0436\u043d\u0456\u0439 \u0441\u043f\u0438\u0441\u043e\u043a\n    empty_list = []\n\n    # \u0421\u043f\u0438\u0441\u043e\u043a \u0447\u0438\u0441\u0435\u043b\n    numbers = [10, 20, 30, 40]\n</code></pre> Tip <p>\u0429\u043e\u0431 \u0441\u0442\u0432\u043e\u0440\u0438\u0442\u0438 \u043f\u043e\u0440\u043e\u0436\u043d\u0456\u0439 \u0441\u043f\u0438\u0441\u043e\u043a, \u043c\u043e\u0436\u043d\u0430 \u0432\u0438\u043a\u043e\u0440\u0438\u0441\u0442\u0430\u0442\u0438 list()</p> <pre><code>my_list = list()\n</code></pre>"},{"location":"list/#2","title":"2. \u0406\u043d\u0434\u0435\u043a\u0441\u0438","text":"<p>\u041a\u043e\u0436\u0435\u043d \u0435\u043b\u0435\u043c\u0435\u043d\u0442 \u0443 \u0441\u043f\u0438\u0441\u043a\u0443 \u043c\u0430\u0454 \u0441\u0432\u0456\u0439 \"\u043d\u043e\u043c\u0435\u0440\" \u0442\u043e\u0431\u0442\u043e \u0456\u043d\u0434\u0435\u043a\u0441.</p> <pre><code>fruits = [\"\u044f\u0431\u043b\u0443\u043a\u043e\", \"\u0431\u0430\u043d\u0430\u043d\", \"\u0430\u043f\u0435\u043b\u044c\u0441\u0438\u043d\"]\n#            0         1         2\n\n# \u041e\u0442\u0440\u0438\u043c\u0443\u0454\u043c\u043e \u0435\u043b\u0435\u043c\u0435\u043d\u0442 \u0437\u0430 \u0456\u043d\u0434\u0435\u043a\u0441\u043e\u043c:\nprint(fruits[0]) # \u044f\u0431\u043b\u0443\u043a\u043e\nprint(fruits[2]) # \u0430\u043f\u0435\u043b\u044c\u0441\u0438\u043d\n</code></pre> Tip <p>\u0412 Python \u0456\u043d\u0434\u0435\u043a\u0441\u0430\u0446\u0456\u044f \u043f\u043e\u0447\u0438\u043d\u0430\u0454\u0442\u044c\u0441\u044f \u0437 0</p>"},{"location":"list/#_1","title":"\u0417\u0432\u043e\u0440\u043e\u0442\u043d\u0430 \u043d\u0443\u043c\u0435\u0440\u0430\u0446\u0456\u044f","text":"<p>\u042f\u043a\u0449\u043e \u043f\u043e\u0442\u0440\u0456\u0431\u043d\u043e \u0432\u0437\u044f\u0442\u0438 \u0435\u043b\u0435\u043c\u0435\u043d\u0442\u0438 \u0437 \u043a\u0456\u043d\u0446\u044f \u0441\u043f\u0438\u0441\u043a\u0443, \u0432\u0438\u043a\u043e\u0440\u0438\u0441\u0442\u043e\u0432\u0443\u044e\u0442\u044c \u043c\u0456\u043d\u0443\u0441\u043e\u0432\u0456 \u0456\u043d\u0434\u0435\u043a\u0441\u0438. \u041e\u0441\u0442\u0430\u043d\u043d\u0456\u0439 \u0435\u043b\u0435\u043c\u0435\u043d\u0442 \u2014 \u0437\u0430\u0432\u0436\u0434\u0438 [-1]</p> <pre><code>print(fruits[-1])  # \u0430\u043f\u0435\u043b\u044c\u0441\u0438\u043d\nprint(fruits[-2])  # \u0431\u0430\u043d\u0430\u043d\n</code></pre>"},{"location":"list/#3","title":"3. \u0417\u043c\u0456\u043d\u0430 \u0435\u043b\u0435\u043c\u0435\u043d\u0442\u0456\u0432 \u0441\u043f\u0438\u0441\u043a\u0443","text":"<p>\u0421\u043f\u0438\u0441\u043a\u0438 \u0454 \u0437\u043c\u0456\u043d\u043d\u0438\u043c\u0438. \u0426\u0435 \u043e\u0437\u043d\u0430\u0447\u0430\u0454, \u0449\u043e \u0432\u0438 \u043c\u043e\u0436\u0435\u0442\u0435 \u043b\u0435\u0433\u043a\u043e \u0437\u0430\u043c\u0456\u043d\u0438\u0442\u0438 \u0431\u0443\u0434\u044c-\u044f\u043a\u0438\u0439 \u0435\u043b\u0435\u043c\u0435\u043d\u0442.</p>"},{"location":"list/#4-c","title":"4. \u041e\u0441\u043d\u043e\u0432\u043d\u0456 \u043c\u0435\u0442\u043e\u0434\u0438 c\u043f\u0438\u0441\u043a\u0456\u0432","text":"<ul> <li>append()</li> <li>remove()</li> <li>index()</li> </ul>"},{"location":"list/#append","title":"\u041c\u0435\u0442\u043e\u0434 append()","text":"<p>\u041c\u0435\u0442\u043e\u0434 append() \u0434\u043e\u0434\u0430\u0454 \u043d\u043e\u0432\u0456 \u0435\u043b\u0435\u043c\u0435\u043d\u0442\u0438 \u0434\u043e \u0441\u043f\u0438\u0441\u043a\u0443:</p> <pre><code>my_list = []\nmy_list.append('apple')\n</code></pre>"},{"location":"list/#remove","title":"\u041c\u0435\u0442\u043e\u0434 remove()","text":"<p>\u041c\u0435\u0442\u043e\u0434 remove() \u0432\u0438\u0434\u0430\u043b\u044f\u0454 \u0435\u043b\u0435\u043c\u0435\u043d\u0442\u0438 \u0437\u0456 \u0441\u043f\u0438\u0441\u043a\u0443: <pre><code>my_list = ['apple','golden_apple', 'gold']\nmy_list.remove('gold')\n</code></pre></p>"},{"location":"list/#index","title":"\u041c\u0435\u0442\u043e\u0434 index()","text":"<p>\u041c\u0435\u0442\u043e\u0434 inde() \u043f\u043e\u0432\u0435\u0440\u0442\u0430\u0454 \u0456\u043d\u0434\u0435\u043a\u0441 \u0446\u044c\u043e\u0433\u043e \u0435\u043b\u0435\u043c\u0435\u043d\u0442\u0430(\u044f\u043a\u0449\u043e \u0432\u0456\u043d \u0454) <pre><code>my_list = ['apple','golden_apple']\nmy_list.index('apple') # \u0431\u0443\u0434\u0435 0 \n</code></pre></p>"},{"location":"variables/","title":"\u0417\u043c\u0456\u043d\u043d\u0456","text":""},{"location":"variables/#_2","title":"\u0417\u043c\u0456\u043d\u043d\u0430 \u2014 \u0446\u0435 \u0456\u043c'\u044f, \u044f\u043a\u0435 \u043c\u0438 \u0434\u0430\u0454\u043c\u043e \u044f\u043a\u043e\u043c\u0443\u0441\u044c \u0437\u043d\u0430\u0447\u0435\u043d\u043d\u044e, \u0449\u043e\u0431 \u043a\u043e\u043c\u043f'\u044e\u0442\u0435\u0440 \u0439\u043e\u0433\u043e \u0437\u0430\u043f\u0430\u043c'\u044f\u0442\u0430\u0432","text":"<p>\u0417\u043c\u0456\u043d\u043d\u0456 \u043c\u043e\u0436\u043a\u0443\u044c \u043c\u0430\u0442\u0438 \u044f\u043a \u0434\u0430\u043d\u0456 \u0442\u0430\u043a \u0456 \u044f\u043a\u0456\u0441\u044c \u0432\u0438\u0440\u0430\u0437\u0438:</p> <pre><code>a = 10\n</code></pre> <p>\u0412 \u043d\u0430\u0448\u043e\u043c\u0443 \u043a\u043e\u0434\u0456 \u043c\u0438 \u0441\u0442\u0432\u043e\u0440\u044e\u0454\u043c\u0430 \u0437\u043c\u0456\u043d\u043d\u0443 \u0437 \u0456\u043c'\u044f\u043c a, \u0442\u0430 \u043f\u0440\u0438\u0432\u043b\u0430\u0441\u043d\u044e\u0454\u043c\u043e \u0437\u043d\u0430\u0447\u0435\u043d\u043d\u044f 10</p>"},{"location":"variables/#_3","title":"\u0422\u0438\u043f\u0438 \u0434\u0430\u043d\u0438\u0445","text":"<p>\u041f\u0435\u0440\u0435\u0434 \u0442\u0438\u043c \u044f\u043a \u043c\u0438 \u043f\u0440\u043e\u0434\u043e\u0432\u0436\u0435\u043c\u043e, \u0445\u043e\u0442\u0456\u0432 \u0440\u043e\u0437\u043f\u043e\u0432\u0456\u0441\u0442\u0438 \u043f\u0440\u043e \u043e\u0441\u043d\u043e\u0432\u043d\u0456 \u0442\u0438\u043f\u0438 \u0434\u0430\u043d\u0438\u0445:</p> name description int \u0446\u0456\u043b\u0435 \u0447\u0438\u0441\u043b\u043e(1,2,3...876...) float \u0434\u0440\u043e\u0431\u043e\u0432\u0435 \u0447\u0438\u0441\u043b\u043e(1.05,24.7...) str \u0442\u0435\u043a\u0441\u0442('hello',\"null\"...) bool \u0456\u0441\u0442\u0438\u043d\u0430 \u0447\u0438 \u043d\u0456(True,False) <p>\u0412 Python \u0442\u0435\u043a\u0441\u0442 \u043c\u043e\u0436\u043d\u0430 \u043f\u0438\u0441\u043f\u0442\u0438 \u044f\u043a \u0432 '' \u0442\u0430\u043a \u0456 \u0432 \"\"</p> <p>\u0412 Python True \u0442\u0430 False \u043f\u0438\u0448\u0443\u0442\u044c\u0441\u044f \u0437 \u0432\u0435\u043b\u0438\u043a\u043e\u0457 \u043b\u0456\u0442\u0435\u0440\u0438</p>"},{"location":"variables/#_4","title":"\u041f\u043e\u0432\u0435\u0440\u0442\u0430\u0454\u043c\u043e\u0441\u044c \u0434\u043e \u0437\u043c\u0456\u043d\u043d\u0438\u0445:","text":"<p><pre><code>a = 1+4\n</code></pre> \u042f\u043a \u044f \u0432\u0436\u0435 \u043a\u0430\u0437\u0430\u0432 \u0432 \u0437\u043c\u0456\u043d\u043d\u0438\u0445 \u043c\u043e\u0436\u043d\u0430 \u0437\u0430\u043f\u0438\u0441\u0443\u0432\u0430\u0442\u0438 \u044f\u043a\u0456\u0441\u044c \u0434\u0456\u0457. \u0422\u0430\u043a \u043e\u0442, \u043a\u043e\u043b\u0438 \u043c\u0438 \u043d\u0430\u0434\u0440\u0443\u043a\u0443\u0454\u043c\u043e a, \u0442\u043e \u0431\u0443\u0434\u0435 5(Python \u043c\u043e\u0436\u0435 \u0432\u0438\u0440\u0456\u0448\u0443\u0432\u0430\u0442\u0438 \u043f\u0440\u0438\u043a\u043b\u0430\u0434\u0438).</p>"},{"location":"variables/#file-in-development","title":"FILE IN DEVELOPMENT","text":""},{"location":"OOP/01/","title":"\u041a\u043b\u0430\u0441\u0438 \u0442\u0430 \u043e\u0431'\u0454\u043a\u0442\u0438(\u041e\u041e\u041f)","text":""},{"location":"OOP/01/#_2","title":"\u0421\u0442\u0432\u043e\u0440\u0435\u043d\u043d\u044f \u041a\u043b\u0430\u0441\u0441\u0443","text":"<p>\u0412\u0438 \u0432\u0436\u0435 \u0437\u043d\u0430\u0454\u0442\u0435:  \u0424\u0443\u043d\u043a\u0446\u0456\u0457, If, \u0426\u0438\u043a\u043b\u0438... \u0426\u0435\u0439 \u0443\u0440\u043e\u043a \u0431\u0443\u0434\u0435 \u043f\u0440\u0438\u0441\u0432\u044f\u0446\u0435\u043d\u0438\u0439 \u041a\u043b\u0430\u0441\u0441\u0430\u043c.</p> <p>\u041a\u043b\u0430\u0441\u0441 - \u0446\u0435...</p> <p>\u0414\u0430\u0432\u0430\u0439\u0442\u0435 \u0440\u043e\u0437\u0433\u043b\u044f\u043d\u0435\u043c\u043e \u043f\u0440\u0438\u043a\u043b\u0430\u0434:</p> main.py <pre><code>\ngraph TD\n\n    A[\"**\u041f\u0440\u0435\u0434\u043c\u0435\u0442**&lt;br/&gt;(\u041c\u0430\u0454 \u043c\u0430\u0441\u0443 \u0442\u0430 \u043e\u0431'\u0454\u043c)\"] \n\n    A --&gt; B[\"**\u0416\u0438\u0432\u0456**&lt;br/&gt;(\u0414\u0438\u0445\u0430\u044e\u0442\u044c, \u0440\u043e\u0441\u0442\u0443\u0442\u044c, \u0436\u0438\u0432\u043b\u044f\u0442\u044c\u0441\u044f)\"]\n    A --&gt; C[\"**\u041d\u0435\u0436\u0438\u0432\u0456**&lt;br/&gt;(\u041d\u0435 \u0434\u0438\u0445\u0430\u044e\u0442\u044c, \u043d\u0435 \u0440\u043e\u0441\u0442\u0443\u0442\u044c)\"]\n\n    B --&gt; D[\"**\u0422\u0432\u0430\u0440\u0438\u043d\u0438**&lt;br/&gt;(\u0410\u043a\u0442\u0438\u0432\u043d\u043e \u0440\u0443\u0445\u0430\u044e\u0442\u044c\u0441\u044f)\"]\n    B --&gt; E[\"**\u0420\u043e\u0441\u043b\u0438\u043d\u0438**&lt;br/&gt;(\u0412\u0438\u0440\u043e\u0431\u043b\u044f\u044e\u0442\u044c \u043a\u0438\u0441\u0435\u043d\u044c)\"]\n\n    D --&gt; D1[\"**\u041a\u043e\u0448\u0435\u043d\u044f**&lt;br/&gt;(\u041c\u0443\u0440\u043a\u043e\u0447\u0435, \u0433\u0440\u0430\u0454\u0442\u044c\u0441\u044f)\"]\n    E --&gt; E1[\"**\u041a\u0432\u0456\u0442\u043a\u0430**&lt;br/&gt;(\u0426\u0432\u0456\u0442\u0435, \u043f\u0430\u0445\u043d\u0435)\"]\n\n    C --&gt; C1[\"**\u0421\u0442\u0456\u043b**&lt;br/&gt;(\u041c\u0456\u0446\u043d\u0438\u0439, \u0434\u0435\u0440\u0435\u0432'\u044f\u043d\u0438\u0439)\"]</code></pre> <p>\u0412 \u043d\u0430\u0448\u043e\u043c\u0443 \u0432\u0438\u043f\u0430\u0434\u043a\u0443 \u0432\u0441\u0456 \u0431\u043b\u043e\u043a\u0438 \u0446\u0435 \u043a\u043b\u0430\u0441\u0438 \u0442\u0430 \u043a\u043e\u0436\u0435\u043d \u043a\u043b\u0430\u0441 \u043c\u0430\u0454 \u0456\u043c'\u044f. \u0422\u0430\u043a\u043e\u0436 \u043a\u043b\u0430\u0441\u0438 \u043c\u0430\u044e\u0442\u044c \u0440\u0456\u0437\u043d\u0456 \u0432\u043b\u0430\u0441\u0442\u0438\u0432\u043e\u0441\u0442\u0456. \u0422\u0430 \u0432\u0441\u0456 \u043a\u043b\u0430\u0441\u0438 \u044f\u043a\u0456 \u043f\u043e\u0445\u043e\u0434\u044f\u0442\u044c \u0432\u0456\u0434 \u0456\u043d\u0448\u0438\u0445 \u043a\u043b\u0430\u0441\u0456\u0432(\u0442\u043e\u0431\u0442\u043e \u043c\u0430\u044e\u0442\u044c \u0441\u0445\u043e\u0436\u0456 \u0432\u043b\u0430\u0441\u0442\u0438\u0432\u043e\u0441\u0456) \u0431\u0435\u0440\u0443\u0442\u044c \u0432\u0456\u0434 \u0441\u0432\u043e\u0457\u044e \u0431\u0430\u0442\u044c\u043a\u0456\u0432 \u0432\u043b\u0430\u0441\u0442\u0438\u0432\u043e\u0441\u0442\u0456 \u0442\u0430 \u043c\u0430\u044e\u0442\u044c \u0441\u0432\u043e\u0457.</p> <p>\u0429\u043e\u0431 \u0441\u0442\u0432\u043e\u0440\u0438\u0442\u0438 \u0441\u0432\u0456\u0439 \u043a\u043b\u0430\u0441, \u0442\u0440\u0435\u0431\u0430:</p> <p>1.\u0412\u0438\u043a\u043e\u0440\u0438\u0441\u0442\u043e\u0432\u0443\u0432\u0430\u0442\u0438 \u043a\u043b\u044e\u0447\u043e\u0432\u0435 \u0441\u043b\u043e\u0432\u043e class</p> <p>2.\u0421\u0442\u0432\u043e\u0440\u0438\u0442\u0438 \u0456\u043c'\u044f \u0434\u043b\u044f \u043a\u043b\u0430\u0441\u0443</p> <p>3.\u0414\u043e\u0434\u0430\u0432\u0430\u0442\u0438 \u0444\u0443\u043d\u043a\u0446\u0456\u0457 \u0456 \u0442\u0430\u043a\u0435 \u0456\u043d\u0448\u0435</p> <p>\u041d\u0430\u0432\u0435\u0434\u0443 \u043f\u0440\u043e\u0441\u0442\u0438\u0439 \u043f\u0440\u0438\u043a\u043b\u0430\u0434:</p> oop.py<pre><code>class Subject():\n    pass\n</code></pre> <p>\u042f\u043a \u043c\u0438 \u0431\u0430\u0447\u0438\u043c\u043e \u0432\u0438\u043a\u043e\u0440\u0438\u0441\u0442\u043e\u0432\u0443\u0454\u0442\u044c\u0441\u044f \u043a\u043b\u044e\u0447\u043e\u0432\u0435 \u0441\u043b\u043e\u0432\u043e class</p> Tip <p>\u041a\u043b\u0430\u0441\u0438 \u0437\u0430\u0432\u0436\u0434\u0438 \u043f\u0438\u0448\u0443\u0442\u044c\u0441\u044f \u0437 \u0432\u0435\u043b\u0438\u043a\u043e\u0457 \u043b\u0456\u0442\u0435\u0440\u0438</p> <p>\u0412\u0430\u0436\u043b\u0438\u0432\u043e \u043f\u0430\u043c'\u044f\u0442\u0430\u0442\u0438 \u043f\u0440\u043e \u0442\u0435 \u0449\u043e \u043e\u0442\u0441\u0442\u0443\u043f\u0438 \u0432 Python \u0434\u0443\u0436\u0435 \u0432\u0430\u0436\u043b\u0438\u0432\u0456</p> <p>\u0422\u043e\u043c\u0443 \u043f\u0430\u043c'\u044f\u0442\u0430\u0439\u0442\u0435:</p> Failure <pre><code>class Subject():\npass\n</code></pre> Success <pre><code>class Subject():\n    pass\n</code></pre>"},{"location":"OOP/01/#_3","title":"\u0406\u043d\u0456\u0446\u0456\u0430\u043b\u0456\u0437\u0430\u0446\u0456\u044f \u0442\u0430 \u0435\u043a\u0437\u0435\u043f\u043b\u044f\u0440 \u043a\u043b\u0430\u0441\u0441\u0430","text":"<p>\u0412\u0438 \u0432\u0436\u0435 \u043e\u0437\u043d\u0430\u0439\u043e\u043c\u0438\u043b\u0438\u0441\u044c \u0437 \u043e\u0441\u043d\u043e\u0432\u043e\u0439 \u0442\u043e\u043c\u0443 \u043f\u0435\u0440\u0435\u0439\u0434\u0435\u043c\u043e \u0434\u043e \u0431\u0456\u043b\u044c\u0448 \u0441\u043a\u043b\u0430\u0434\u043d\u043e\u0457 \u0447\u0430\u0441\u0442\u0438\u043d\u0438</p>"}]}